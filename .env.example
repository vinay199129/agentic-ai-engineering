# Copy to `.env` and fill in. Never commit `.env`.

# --- LLM providers (a litellm shim chooses between these) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# --- Embeddings / reranking ---
COHERE_API_KEY=
VOYAGE_API_KEY=

# --- Search tools ---
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Observability (self-hosted Langfuse, set up in 07-deployment-patterns/02-docker-compose-stack) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Local mode toggles ---
# When set, notebooks/CI use cached LLM responses instead of live calls.
LLM_CACHE_ONLY=0
